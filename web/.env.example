# ── Azmera Frontend — Environment Variables ───────────────────────
# Copy this file to .env.local and fill in values.

# URL of the Python FastAPI/Flask backend.
# In development: http://localhost:8000
# In production: your deployed backend URL (e.g. https://api.azmera.example.com)
PYTHON_API_BASE=http://127.0.0.1:8000
